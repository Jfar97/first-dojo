#!/usr/bin/env python3
import subprocess

G = "/nix/store/w1hyhaxq3h9195bllxpbgq58f3jqzn91-ghidra-11.3.2"

subprocess.run([f"{G}/bin/ghidra-analyzeHeadless", "/home/hacker", "pwnproj",
                "-import", "/challenge/executable", "-overwrite"],
               stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)

subprocess.Popen([f"{G}/bin/ghidra", "/home/hacker/pwnproj.gpr"])

print("Ghidra opened. Double-click 'executable', then Window -> Script Manager -> run rename.py")
